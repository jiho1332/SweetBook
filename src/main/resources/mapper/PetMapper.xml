<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sweetbook.mapper.PetMapper">

    <resultMap id="petMap" type="com.sweetbook.vo.PetVO">
        <id property="petId" column="pet_id"/>
        <result property="petToken" column="pet_token"/>
        <result property="name" column="name"/>
        <result property="profileImageUrl" column="profile_image_url"/>
        <result property="memorialDate" column="memorial_date"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insertPet"
            parameterType="com.sweetbook.vo.PetVO"
            useGeneratedKeys="true"
            keyProperty="petId">
        INSERT INTO pet (
            member_id,
            pet_token,
            name,
            profile_image_url,
            memorial_date
        ) VALUES (
            1,
            #{petToken},
            #{name},
            #{profileImageUrl},
            #{memorialDate}
        )
    </insert>

    <select id="selectPetById" parameterType="long" resultMap="petMap">
        SELECT
            pet_id,
            pet_token,
            name,
            profile_image_url,
            memorial_date,
            created_at
        FROM pet
        WHERE pet_id = #{petId}
    </select>

    <select id="selectPetList" resultMap="petMap">
        SELECT
            pet_id,
            pet_token,
            name,
            profile_image_url,
            memorial_date,
            created_at
        FROM pet
        ORDER BY pet_id DESC
    </select>

    <select id="selectPetListByMemberId" parameterType="long" resultMap="petMap">
        SELECT
            pet_id,
            pet_token,
            name,
            profile_image_url,
            memorial_date,
            created_at
        FROM pet
        WHERE member_id = #{memberId}
        ORDER BY pet_id DESC
    </select>

    <update id="updatePet" parameterType="com.sweetbook.vo.PetVO">
        UPDATE pet
        SET
            name = #{name},
            profile_image_url = #{profileImageUrl},
            memorial_date = #{memorialDate}
        WHERE pet_id = #{petId}
    </update>

    <delete id="deletePet" parameterType="long">
        DELETE FROM pet
        WHERE pet_id = #{petId}
    </delete>

</mapper>